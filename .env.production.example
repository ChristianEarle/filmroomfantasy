# Production API URL - used when building for production
# Replace with your deployed Cloudflare Worker URL + /api
# Example: https://filmroom-api.<your-subdomain>.workers.dev/api
VITE_API_URL=https://filmroom-api.<your-subdomain>.workers.dev/api

# ----------------------------------------------------------------------------
# Ad-platform tracking pixels (all optional — leave blank to disable a platform).
# Pixels stay dormant until the visitor grants the matching cookie consent.
# Wire-up: src/services/tracking.ts. Events fired: page_view, sign_up,
# begin_checkout, purchase.
# ----------------------------------------------------------------------------

# Google Analytics 4 (requires "analytics" cookie consent). Format: G-XXXXXXXXXX
VITE_GA4_ID=

# Meta (Facebook/Instagram) Pixel (requires "advertising" consent). Numeric ID.
VITE_META_PIXEL_ID=

# Google Ads conversion tag (requires "advertising" consent). Format: AW-XXXXXXXXXX
VITE_GOOGLE_ADS_ID=
# Conversion labels from Google Ads → Tools → Conversions (the part after the slash).
VITE_GOOGLE_ADS_SIGNUP_LABEL=
VITE_GOOGLE_ADS_PURCHASE_LABEL=

# TikTok Pixel (requires "advertising" consent). Format: C... (sdkid)
VITE_TIKTOK_PIXEL_ID=

# Reddit Pixel (requires "advertising" consent). Format: a2_xxxxxxxx
VITE_REDDIT_PIXEL_ID=
